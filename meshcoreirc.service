[Unit]
Description=MeshCore IRC Gateway
After=network.target

[Service]
Type=simple
User=meshcoreirc
Group=meshcoreirc
SupplementaryGroups=dialout
WorkingDirectory=/home/meshcoreirc/MeshCoreIRC
ExecStart=/home/meshcoreirc/MeshCoreIRC/.venv/bin/python3 main.py
Restart=on-failure
RestartSec=30s

[Install]
WantedBy=multi-user.target
